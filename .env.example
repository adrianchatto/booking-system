# Database — PostgreSQL connection string
# For local dev: postgresql://user:password@localhost:5432/bookright
# For Render: copy from your Render PostgreSQL dashboard
DATABASE_URL="postgresql://user:password@localhost:5432/bookright"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# For local dev
NEXTAUTH_URL="http://localhost:3000"
# For production on Render, set this to your Render URL e.g.:
# NEXTAUTH_URL="https://bookright-platform.onrender.com"

# Anthropic API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-your-key-here"
